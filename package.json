{
  "name": "wend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter './apps/*' dev",
    "dev:web": "pnpm --filter web dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:api": "pnpm --filter api dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @wend/db generate",
    "db:migrate": "pnpm --filter @wend/db migrate",
    "db:studio": "pnpm --filter @wend/db studio",
    "db:seed": "pnpm --filter @wend/db seed"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "catalog:"
  }
}
